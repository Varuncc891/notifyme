generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String   @id @default(cuid())

  url       String
  payload   Json

  status    String

  retries   Int      @default(0)

  lastError String?

  createdAt DateTime @default(now())
}